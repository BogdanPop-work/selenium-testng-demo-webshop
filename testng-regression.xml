<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite">
	<listeners>
		<listener class-name="com.bogdan.automation.listeners.TestListener" />
	</listeners>

	<test name="Regression Tests">

		<groups>
			<run>
				<include name="smoke" />
				<include name="regression" />
			</run>
		</groups>

		<packages>
			<package name="com.bogdan.automation.tests.*" />
		</packages>

	</test>

</suite>